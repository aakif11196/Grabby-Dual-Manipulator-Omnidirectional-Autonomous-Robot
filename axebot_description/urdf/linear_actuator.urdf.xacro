<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- Linear actuator macro for vertical positioning of manipulators -->
  <xacro:macro name="linear_actuator" params="prefix parent *origin">
    
    <!-- Actuator base link (Fixed housing: Box + Outer Tube) -->
    <link name="${prefix}_actuator_base_link">
      <!-- Bottom Box -->
      <visual>
        <origin xyz="0 0 0.025" rpy="0 0 0"/>
        <geometry>
          <box size="0.08 0.08 0.05"/>
        </geometry>
        <material name="dark_grey">
          <color rgba="0.3 0.3 0.3 1.0"/>
        </material>
      </visual>
      <collision>
        <origin xyz="0 0 0.025" rpy="0 0 0"/>
        <geometry>
          <box size="0.08 0.08 0.05"/>
        </geometry>
      </collision>

      <!-- Fixed Outer Cylinder -->
      <visual>
        <origin xyz="0 0 0.2" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="0.04" length="0.3"/>
        </geometry>
        <material name="dark_grey">
          <color rgba="0.3 0.3 0.3 1.0"/>
        </material>
      </visual>
      <collision>
        <origin xyz="0 0 0.2" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="0.04" length="0.3"/>
        </geometry>
      </collision>

      <inertial>
        <origin xyz="0 0 0.1" rpy="0 0 0"/>
        <mass value="2.0"/>
        <inertia ixx="0.01" ixy="0.0" ixz="0.0"
                 iyy="0.01" iyz="0.0"
                 izz="0.001"/>
      </inertial>
    </link>

    <!-- Joint connecting actuator base to parent -->
    <joint name="${prefix}_actuator_fixed_joint" type="fixed">
      <xacro:insert_block name="origin"/>
      <parent link="${parent}"/>
      <child link="${prefix}_actuator_base_link"/>
    </joint>

    <!-- Moving platform link (Inner Cylinder) -->
    <link name="${prefix}_actuator_platform_link">
      <!-- Inner Cylinder (Rod) -->
      <visual>
        <origin xyz="0 0 -0.2" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="0.025" length="0.4"/>
        </geometry>
        <material name="silver"/>
      </visual>
      <collision>
        <origin xyz="0 0 -0.2" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="0.025" length="0.4"/>
        </geometry>
      </collision>

      <inertial>
        <origin xyz="0 0 -0.2" rpy="0 0 0"/>
        <mass value="1.0"/>
        <inertia ixx="0.01" ixy="0.0" ixz="0.0"
                 iyy="0.01" iyz="0.0"
                 izz="0.001"/>
      </inertial>
    </link>

    <!-- Prismatic joint for vertical movement -->
    <joint name="${prefix}_actuator_joint" type="prismatic">
      <!-- 
           Base height = 0.05 (box) + 0.3 (tube). Top of tube is at 0.05 + 0.3 = 0.35? 
           Actually tube origin at 0.2 means it goes from 0.05 to 0.35.
           Let's place the joint at the top of the fixed tube: 0.35.
      -->
      <origin xyz="0 0 0.35" rpy="0 0 0"/>
      <parent link="${prefix}_actuator_base_link"/>
      <child link="${prefix}_actuator_platform_link"/>
      <axis xyz="0 0 1"/>
      <limit lower="0.0" upper="0.3" effort="100.0" velocity="0.1"/>
      <dynamics damping="10.0" friction="1.0"/>
    </joint>

  </xacro:macro>

</robot>
